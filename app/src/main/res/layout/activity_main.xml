<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PUMP Paper Bot"
            android:textColor="#F0F6FC"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvGlobalStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Status: stopped"
            android:textColor="#8B949E"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvMode4h"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="#1F6FEB"
                android:gravity="center"
                android:text="4H PRIMARY STATS"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMode2h"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="#30363D"
                android:gravity="center"
                android:text="2H EXPERIMENT STATS"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/statsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#161B22"
            android:minHeight="190dp"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvSelectedStatsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4H PRIMARY STATISTICS"
                android:textColor="#F0F6FC"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSelectedStatsSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Invested: 1000.00 USDT"
                android:textColor="#C9D1D9"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvSelectedStatsDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Trades: 0 | Fees: 0.00 USDT"
                android:textColor="#8B949E"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSelectedStatsTrades"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="No trades yet."
                android:textColor="#C9D1D9"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#161B22"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvPrimaryTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Primary 4H"
                android:textColor="#F0F6FC"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPrimaryBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="1000.00 USDT"
                android:textColor="#F0F6FC"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPrimaryMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Position: none"
                android:textColor="#C9D1D9"
                android:textSize="13sp" />

            <com.example.pumppaperbot.StrategyChartView
                android:id="@+id/chartPrimary"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/tvPrimaryDecision"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Decision: -"
                android:textColor="#8B949E"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#161B22"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvExperimentalTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Experiment 2H + 4H"
                android:textColor="#F0F6FC"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvExperimentalBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="1000.00 USDT"
                android:textColor="#F0F6FC"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvExperimentalMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Position: none"
                android:textColor="#C9D1D9"
                android:textSize="13sp" />

            <com.example.pumppaperbot.StrategyChartView
                android:id="@+id/chartExperimental"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="10dp" />

            <TextView
                android:id="@+id/tvExperimentalDecision"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Decision: -"
                android:textColor="#8B949E"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:backgroundTint="#238636"
                android:text="START"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCheck"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#1F6FEB"
                android:text="CHECK"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:backgroundTint="#6E7681"
                android:text="STOP"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#DA3633"
                android:text="RESET"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnBacktest"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#2F81F7"
            android:text="BACKTEST"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
