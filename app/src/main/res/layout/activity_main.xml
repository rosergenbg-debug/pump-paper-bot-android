<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PUMP Сигнал RSI35"
            android:textColor="#F0F6FC"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Остановлено"
            android:textColor="#8B949E"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvMode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="#30363D"
            android:gravity="center"
            android:text="Режим: жду покупку"
            android:textColor="#C9D1D9"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRisk30"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:backgroundTint="#30363D"
                android:text="РИСК 30"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnRisk35"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#238636"
                android:text="РИСК 35"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvBuySignal"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:background="#161B22"
                android:gravity="center"
                android:text="Покупка: нет"
                android:textColor="#8B949E"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSellSignal"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="#161B22"
                android:gravity="center"
                android:text="Продажа: нет"
                android:textColor="#8B949E"
                android:textSize="21sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#161B22"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PUMP цена - | RSI -"
                android:textColor="#F0F6FC"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Нажмите ЗАПУСТИТЬ"
                android:textColor="#8B949E"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPosition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Позиция: нет"
                android:textColor="#C9D1D9"
                android:textSize="14sp" />

            <com.example.pumppaperbot.StrategyChartView
                android:id="@+id/chart"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:backgroundTint="#238636"
                android:text="ЗАПУСТИТЬ"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCheck"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#1F6FEB"
                android:text="ПРОВЕРИТЬ"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:backgroundTint="#6E7681"
                android:text="СТОП"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#DA3633"
                android:text="СБРОС"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnManual"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#238636"
            android:text="Я КУПИЛ - ЖДАТЬ ПРОДАЖУ"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnToggleMode"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:backgroundTint="#30363D"
                android:text="ЖДАТЬ ПРОДАЖУ"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnBacktest"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#2F81F7"
                android:text="ПРОВЕРКА НАЗАД"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
